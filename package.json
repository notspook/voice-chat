{
  "name": "ripple",
  "version": "2.0.0",
  "description": "Voice chat with servers, DMs, calls, music bot, screen sharing",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm rebuild better-sqlite3 2>nul && node server.js",
    "postinstall": "npm rebuild better-sqlite3 2>nul || true",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@livekit/rtc-node": "^0.13.0",
    "better-sqlite3": "^12.11.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "jimp": "^1.6.1",
    "livekit-server-sdk": "^2.17.0",
    "play-dl": "^1.9.7",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.ripple.voicechat",
    "productName": "Ripple",
    "directories": { "output": "dist" },
    "files": ["electron/**/*", "server.js", "public/**/*", "package.json"],
    "win": { "target": "portable", "icon": "electron/icon.ico", "signAndEditExecutable": false }
  }
}
